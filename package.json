{
  "name": "lutest",
  "private": false,
  "packageManager": "npm@10.5.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @lutest/cli-host",
    "dev:host": "npm run dev -w @lutest/cli-host",
    "dev:worker": "npm run dev -w @lutest/worker-node",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.4.0"
  }
}
